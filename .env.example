# 服务端口
PORT=8080
# Docker Compose 暴露到宿主机的端口
HOST_PORT=8080

# 远程 MySQL 配置（必填）
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASS=yourpassword
DB_NAME=miaodi_agent
DB_MAX_OPEN=50
DB_MAX_IDLE=10
# 容器日志和应用默认时区
TZ=Asia/Shanghai
# 打印 webhook 入参、程序回包、Agent 决策、工具调用和应用错误
APP_DEBUG=false

# OpenAI 兼容 API（必填）
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_MODEL_MAX_TOKENS=8192
OPENAI_MAX_OUTPUT_TOKENS=1024
# 调试模型请求时开启，会打印请求体和错误响应；生产环境建议保持关闭
OPENAI_DEBUG=false

# 传送鸽回调路径
CALLBACK_PATH=/callback
# 回调鉴权开关（默认关闭）。开启后必须配置 CALLBACK_SECRET，并要求回调方携带签名头。
CALLBACK_AUTH_ENABLED=false
# 回调鉴权密钥。CALLBACK_AUTH_ENABLED=true 时必填。
CALLBACK_SECRET=
# 统计看板 Token。未配置时不注册 /stats 和 /api/stats。
STATS_TOKEN=

# 回调请求体大小限制（字节），默认 1MB
MAX_CALLBACK_BODY_BYTES=1048576

# 喵滴 API endpoint 配置（可选，以下为默认值）
MIAODI_API_BASE_URL=https://api.libv.cc/miaodi
MIAODI_MAIL_API_URL=https://api.miaodiapp.com/api/newmail.php
MIAODI_PICTURE_API_URL=https://picture.miaodiapp.com/api/upload

# Redis 缓存（可选，默认启用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=true
